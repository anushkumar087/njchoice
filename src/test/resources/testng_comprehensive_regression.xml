<?xml version='1.0' encoding='UTF-8' ?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="NJChoice-Regression-Test" verbose="1" preserve-order="true" parallel="false" thread-count="1">
	<listeners>  
		<listener class-name="listener.ListenerTest"/>  
	</listeners>
	
	<!-- REGRESSION TEST: Test with 20 random rows for broader coverage -->
     <test name="ComprehensiveTest-RegressionTest">
     	<parameter name="dataProviderType" value="Random20Rows"/>
         <classes>
             <class name="testAll.ComprehensiveAllSectionsTest">
             	<methods>
             		<include name="testAllSectionsComprehensive"/>
             	</methods>
             </class>
          </classes>
     </test>
</suite>
