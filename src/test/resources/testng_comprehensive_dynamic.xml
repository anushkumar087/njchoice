<?xml version='1.0' encoding='UTF-8' ?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="NJChoice-Comprehensive-Dynamic" verbose="1" preserve-order="true" parallel="false" thread-count="1">
	<listeners>  
		<listener class-name="listener.ListenerTest"/>  
	</listeners>
	
	<!-- DYNAMIC DATA PROVIDER: Change the parameter value to control which data to use -->
	<!-- Valid values: AllRows, First3Rows, First5Rows, First10Rows, Random3Rows, Random5Rows, Random10Rows, Random20Rows, SingleRandomRow -->
	
     <test name="ComprehensiveTest-DynamicData">
     	<parameter name="dataProviderType" value="First3Rows"/>
         <classes>
             <class name="testAll.ComprehensiveAllSectionsTest">
             	<methods>
             		<!-- This test method must use DynamicDataProvider -->
             		<include name="testAllSectionsComprehensive"/>
             	</methods>
             </class>
          </classes>
     </test>
</suite>
